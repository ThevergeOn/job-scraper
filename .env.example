# ────────────────────────────────────────────────────────
# این فایل یه نمونه هست — هیچ مقدار واقعی اینجا نذار!
# کلیدهای واقعی رو فقط در GitHub Secrets ذخیره کن.
# ────────────────────────────────────────────────────────

# کلید API از سایت RapidAPI
# لینک: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key_here

# توکن ربات تلگرام — از @BotFather بگیر
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# آیدی عددی تلگرام خودت — از @userinfobot بگیر
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── اختیاری: Google Sheets ────────────────────────────
# کل محتوای فایل JSON از Google Cloud Service Account
GSHEET_CREDENTIALS={"type":"service_account",...}

# آیدی فایل Google Sheet (از URL)
GSHEET_ID=your_google_sheet_id_here
